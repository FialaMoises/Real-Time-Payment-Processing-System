# ==================================================
# Banco Fiala - Configuração para Supabase (Cloud)
# ==================================================
#
# 1. Copie este arquivo:
#    Windows: copy .env.supabase.example .env.supabase
#    Linux:   cp .env.supabase.example .env.supabase
#
# 2. Preencha com seus dados do Supabase
# 3. Renomeie para .env quando for usar
#
# ==================================================

# Server Configuration
PORT=8080
ENV=production

# ==================================================
# SUPABASE DATABASE
# ==================================================
#
# Como obter:
# 1. Acesse https://supabase.com/dashboard
# 2. Selecione seu projeto
# 3. Settings → Database → Connection String (URI)
# 4. Copie e cole abaixo (substitua [YOUR-PASSWORD])
#
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxx.supabase.co:5432/postgres
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5

# ==================================================
# REDIS (Opcional - pode deixar vazio para MVP)
# ==================================================
#
# Para usar Redis na nuvem:
# - Upstash: https://upstash.com (free tier)
# - Redis Labs: https://redis.com/try-free
#
REDIS_URL=
REDIS_PASSWORD=
REDIS_DB=0

# ==================================================
# RABBITMQ (Opcional - pode deixar vazio para MVP)
# ==================================================
#
# Para usar RabbitMQ na nuvem:
# - CloudAMQP: https://www.cloudamqp.com (free tier)
#
RABBITMQ_URL=

# ==================================================
# JWT Authentication
# ==================================================
#
# ⚠️ IMPORTANTE: Mude para produção!
# Gere um secret forte: openssl rand -base64 32
#
JWT_SECRET=your-super-secret-jwt-key-CHANGE-THIS-IN-PRODUCTION
JWT_EXPIRATION=3600

# ==================================================
# Logging
# ==================================================
LOG_LEVEL=info

# ==================================================
# Exemplo preenchido:
# ==================================================
#
